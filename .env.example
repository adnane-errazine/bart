# BART — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Anthropic (Claude) ────────────────────────────────────────────
# https://console.anthropic.com → API Keys
CLAUDE_API_KEY=sk-ant-api03-...

# ── OpenAI (embeddings) ───────────────────────────────────────────
# https://platform.openai.com → API Keys
OPENAI_API_KEY=sk-proj-...

# ── Qdrant Cloud (vector store) ───────────────────────────────────
# https://cloud.qdrant.io → Cluster → API Keys
QDRANT_API_KEY=eyJ...
QDRANT_URL=https://<cluster-id>.<region>.gcp.cloud.qdrant.io

# ── Supabase (PostgreSQL) ─────────────────────────────────────────
# Use the SESSION POOLER connection string (not the direct host).
# Supabase → Project Settings → Database → Connection string → Session pooler
# Port: 5432, Host: aws-0-<region>.pooler.supabase.com
SUPABASE_PASSWORD=your_db_password
SUPABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# ── ngrok (local tunnel) ──────────────────────────────────────────
# https://dashboard.ngrok.com → Your Authtoken
NGROK_AUTHTOKEN=...
